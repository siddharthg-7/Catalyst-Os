# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Postgres Connection String for Cloud SQL
DATABASE_URL="postgresql://user:password@localhost:5432/founderos?schema=public"

# VITE_CLERK_PUBLISHABLE_KEY: Frontend publishable key from clerk.com dashboard → API Keys.
# Must use VITE_ prefix so Vite exposes it to the browser via import.meta.env
# Starts with pk_test_ (development) or pk_live_ (production)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_PUBLISHABLE_KEY"

# CLERK_SECRET_KEY: Backend secret key from clerk.com dashboard → API Keys.
# Starts with sk_test_ (development) or sk_live_ (production)
CLERK_SECRET_KEY="sk_test_YOUR_SECRET_KEY"
